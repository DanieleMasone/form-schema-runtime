{
  "name": "form-schema-runtime",
  "version": "0.1.0",
  "description": "Framework-agnostic TypeScript runtime for rendering accessible HTML forms from declarative schemas.",
  "type": "module",
  "license": "MIT",
  "author": "Daniele Masone",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/form-schema-runtime.js",
  "module": "./dist/form-schema-runtime.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/form-schema-runtime.js",
      "default": "./dist/form-schema-runtime.js"
    },
    "./styles.css": "./dist/form-schema-runtime.css"
  },
  "unpkg": "./dist/form-schema-runtime.iife.js",
  "jsdelivr": "./dist/form-schema-runtime.iife.js",
  "scripts": {
    "dev": "vite --config vite.demo.config.ts",
    "build": "npm run build:lib && npm run build:demo && npm run build:docs && npm run build:coverage",
    "build:lib": "vite build --config vite.config.ts && tsc -p tsconfig.build.json",
    "build:demo": "vite build --config vite.demo.config.ts",
    "build:docs": "typedoc --options typedoc.json",
    "build:coverage": "node scripts/copy-coverage.mjs",
    "docs": "typedoc --options typedoc.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "preview": "vite preview --config vite.demo.config.ts"
  },
  "keywords": [
    "forms",
    "schema",
    "typescript",
    "accessibility",
    "framework-agnostic"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
